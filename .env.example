# Auth: omit or `local` (default) = email/password in the browser only.
# `firebase` = use Firebase Authentication (requires full VITE_FIREBASE_* config and console setup).

# VITE_AUTH_MODE=local

# Optional: override embedded defaults (src/lib/firebase.ts) when using Firebase auth.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
